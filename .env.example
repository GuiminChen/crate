# CRATE — 复制为 .env 后填写（.env 勿提交到 Git）
# cp .env.example .env

# DeepSeek OpenAI 兼容 API（compile / ask 必填其一）
CRATE_DEEPSEEK_API_KEY=
# 若只用下面这个名字也可以：
# DEEPSEEK_API_KEY=

# 可选（默认已够用）
# CRATE_DEEPSEEK_BASE_URL=https://api.deepseek.com
# CRATE_DEEPSEEK_MODEL=deepseek-chat

# 语义索引（crate index / crate search --semantic；可与 DeepSeek 分开配置）
# CRATE_EMBEDDING_API_KEY=
# 或复用：OPENAI_API_KEY=
# CRATE_EMBEDDING_BASE_URL=https://api.openai.com/v1
# CRATE_EMBEDDING_MODEL=text-embedding-3-small
